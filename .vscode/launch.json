{
    "version": "0.2.0",
    "configurations": [
		{
            "type": "node",
            "request": "launch",
            "name": "All controllers",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/SteamInputConfig2",
            "program": "${workspaceFolder}/SteamInputConfig2/merge-controller.js",
            "args": [
                "all"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Steam Controller",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/SteamInputConfig2",
            "program": "${workspaceFolder}/SteamInputConfig2/merge-controller.js",
            "args": [
                "steamcontroller"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Hori Steampad",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/SteamInputConfig2",
            "program": "${workspaceFolder}/SteamInputConfig2/merge-controller.js",
            "args": [
                "hori"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "XBox Elite",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/SteamInputConfig2",
            "program": "${workspaceFolder}/SteamInputConfig2/merge-controller.js",
            "args": [
                "xboxelite"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ]
} 