{
    "version": "0.2.0",
    "configurations": [
		{
            "type": "node",
            "request": "launch",
            "name": "All controllers",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/MergeScripts",
            "program": "${workspaceFolder}/MergeScripts/merge-controller.js",
            "args": [
                "${workspaceFolder}/SteamInputConfig/controllers.json",
                "all"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Game Actions",
            "skipFiles": [
                "<node_internals>/**"
            ],
