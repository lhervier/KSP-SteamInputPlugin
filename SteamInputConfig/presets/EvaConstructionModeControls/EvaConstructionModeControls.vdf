"ref"
{
    "preset"
	{
		"id"		"#fileName"
		"name"		"EvaConstructionModeControls"
		"group_source_bindings"
		{
			"/groups/EvaConstructionMode/buttons.vdf"					"button_diamond active"
			"/groups/EvaConstructionMode/buttons_modeshift.vdf"			"button_diamond active modeshift"
			"/groups/EvaConstructionMode/left_joystick.vdf"				"joystick active"
			"/groups/EvaConstructionMode/left_joystick_modeshift.vdf"	"joystick active modeshift"
			"/groups/EvaConstructionMode/left_trigger.vdf"				"left_trigger active"
			"/groups/EvaConstructionMode/right_trigger.vdf"				"right_trigger active"
			"/groups/EvaConstructionMode/switches.vdf"					"switch active"

			{{#if rightTrackpad}}
				"/groups/EvaConstructionMode/right_joystick.vdf"		"right_trackpad active"
			{{else}}
				"/groups/EvaConstructionMode/right_joystick.vdf"		"right_joystick active"
				{{#if allowSlowMouse}}
					"/groups/Common/right_joystick-mouse-slow.vdf"		"right_joystick active modeshift"
				{{/if}}
			{{/if}}
			{{#if leftTrackpad}}
				"/groups/Common/dpad-click-zoom.vdf"					"left_trackpad active"
			{{else}}
				"/groups/Common/dpad-click-zoom.vdf"					"dpad active"
			{{/if}}
		}
	}
}