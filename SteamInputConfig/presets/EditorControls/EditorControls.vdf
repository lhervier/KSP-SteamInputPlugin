"ref"
{
    "preset"
	{
		"id"		"#fileName"
		"name"		"EditorControls"
		"group_source_bindings"
		{
			"/groups/four_buttons/editor/reset_rot-delete-sym_cycle-snap.vdf"			"button_diamond active"
			"/groups/four_buttons/editor/place-offset-rotate-root.vdf"					"button_diamond active modeshift"
			"/groups/dpad/editor/rotate-part.vdf"										"joystick active"
			"/groups/dpad/editor/sym-frame.vdf"											"joystick active modeshift"
			"/groups/trigger/editor/right-click-slew.vdf"								"left_trigger active"
			"/groups/trigger/left-click.vdf"											"right_trigger active"
			"/groups/switches/editor.vdf"												"switch active"
			
			{{#if (equals mouseZone "right_trackpad")}}
				"/groups/absolute_mouse/mouse.vdf"										"right_trackpad active"
			{{else}}
				{{#if (true backButtons)}}
					"/groups/joystick_mouse/slow-mouse.vdf"								"right_joystick active modeshift"
					"/groups/joystick_mouse/mouse.vdf"									"right_joystick active"
				{{else}}
					"/groups/joystick_mouse/editor-modeshift.vdf"						"right_joystick active"
				{{/if}}
			{{/if}}
			
			"/groups/dpad/click-scroll.vdf"												"{{dpadZone}} active"
		}
	}
}