"ref"
{
    "preset"
	{
		"id"		"#fileName"
		"name"		"MapFlightControls"
		"group_source_bindings"
		{
			{{! Left Joystick }}
			{{#if (true backButtons)}}
				"/groups/dpad/yaw-pitch.vdf"							"joystick active"
			{{else}}
				"/groups/dpad/yaw-pitch.vdf?with-mod"					"joystick active"
			{{/if}}
			"/groups/hotbar/actiongroups.vdf"							"joystick active modeshift"

			{{! Right Joystick }}
			"#ref"														"right-joystick.vdf?preset=mapflight&dpad=camera"
			
			{{! Left Trackpad }}
			{{#if (equals dpadZone "left_trackpad")}}
				"/groups/dpad/click-zoom.vdf"							"left_trackpad active"
			{{/if}}

			{{! Right Trackpad }}
			{{#if (equals mouseZone "right_trackpad")}}
				"/groups/absolute_mouse/mouse.vdf"						"right_trackpad active"
			{{/if}}

			{{! Button diamond }}
			"/groups/four_buttons/flight/staging-brakes-rcs-sas.vdf"	"button_diamond active"
			"/groups/four_buttons/mapflight/precision-timewarp.vdf"		"button_diamond active modeshift"
			
			{{! Dpad }}
			{{#if (equals dpadZone "dpad")}}
				"/groups/dpad/click-zoom.vdf"							"dpad active"
			{{/if}}

			{{! Left Trigger }}
			"/groups/trigger/throttle-down.vdf"							"left_trigger active"
			{{#unless (true triggersClick)}}
				"/groups/trigger/throttle-cutoff.vdf"					"left_trigger active modeshift"
			{{/unless}}

			{{! Right Trigger }}
			"/groups/trigger/throttle-up.vdf"							"right_trigger active"
			{{#unless (true triggersClick)}}
				"/groups/trigger/full-throttle.vdf"						"right_trigger active modeshift"
			{{/unless}}
			
			{{! Switch }}
			"/groups/switches/mapflight.vdf"							"switch active"
		}
	}
}