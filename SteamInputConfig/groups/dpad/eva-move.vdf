"ref"
{
    "group"
	{
		"id"		"#fileName"
		"mode"		"dpad"
		"name"		""
		"description"		""
		"inputs"
		{
			"#ref"				"/inputs/dpad/east/eva-move-right.vdf"
			"#ref"				"/inputs/dpad/north/eva-move-forward.vdf"
			"#ref"				"/inputs/dpad/south/eva-move-backward.vdf"
			"#ref"				"/inputs/dpad/west/eva-move-left.vdf"
			{{#if (defined with-mod)}}
				"#ref"			"/inputs/dpad/click/mod-key.vdf"
			{{/if}}
		}
	}
}