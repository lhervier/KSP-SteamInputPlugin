"ref"
{
    "group"
	{
		"id"		"#fileName"
		"mode"		"dpad"
		"name"		""
		"description"		""
		"inputs"
		{
			"#ref"				"/inputs/dpad/east/arrow-right.vdf"
			"#ref"				"/inputs/dpad/north/arrow-up.vdf"
			"#ref"				"/inputs/dpad/south/arrow-down.vdf"
			"#ref"				"/inputs/dpad/west/arrow-left.vdf"
			{{#if (defined with-mod)}}
				"#ref"			"/inputs/dpad/click/mod-key.vdf"
			{{/if}}
		}
	}
}