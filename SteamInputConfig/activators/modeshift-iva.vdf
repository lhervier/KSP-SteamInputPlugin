"ref"
{
    "activators"
    {
        {{#if (true allowSlowMouse)}}
            "#ref"                 "/activators/slow-mouse.vdf"
        {{/if}}
        "Full_Press"
        {
            "bindings"
            {
                "binding"		    "mode_shift button_diamond %group_id:/groups/Iva/buttons_modeshift.vdf%"
            }
        }
        "Full_Press"
        {
            "bindings"
            {
                "#ref"			    "/groups/Iva/switches-dpad-modeshift.vdf"
            }
        }
    }
}